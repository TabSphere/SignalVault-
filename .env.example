# ============================================================
# SignalVault Environment Variables
# Copy this file to .env.local and fill in your actual keys
# NEVER commit .env.local to git!
# ============================================================

# --- Supabase (from your Supabase dashboard) ---
NEXT_PUBLIC_SUPABASE_URL=https://dhmswqsggpdrnpaagsvp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...your_service_role_key_here

# --- OpenAI (from platform.openai.com/api-keys) ---
OPENAI_API_KEY=sk-proj-...your_openai_key_here

# --- Stripe (from dashboard.stripe.com/apikeys) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...your_publishable_key
STRIPE_SECRET_KEY=sk_test_...your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_...your_webhook_secret

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_STANDARD=price_...standard_plan_price_id
STRIPE_PRICE_PRO=price_...pro_plan_price_id
STRIPE_PRICE_VIP=price_...vip_plan_price_id

# --- ElevenLabs (from elevenlabs.io/app/settings/api-keys) ---
ELEVENLABS_API_KEY=sk_...your_elevenlabs_key
ELEVENLABS_VOICE_ID=...your_voice_id

# --- App Settings ---
NEXT_PUBLIC_APP_URL=https://signalvault.vercel.app
NEXT_PUBLIC_APP_NAME=SignalVault

# --- CORS ---
# Set this to your production domain for security
# e.g., ALLOWED_ORIGIN=https://signalvault.vercel.app
ALLOWED_ORIGIN=*

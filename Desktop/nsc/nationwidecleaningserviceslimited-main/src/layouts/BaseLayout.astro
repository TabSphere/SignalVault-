---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, canonical, ogImage, noindex } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalURL = canonical || new URL(currentPath, Astro.site).href;
const ogImageURL = ogImage ? new URL(ogImage, Astro.site).href : new URL('/assets/logo.png', Astro.site).href;

// WhatsApp (UK 07836 671796 => 447836671796)
const WHATSAPP_LINK = "https://wa.me/447836671796";

// Social links
const FACEBOOK_LINK = "https://www.facebook.com/share/18BjPVT938/?mibextid=wwXIfr";
const INSTAGRAM_LINK = "#";

// Google Analytics (GA4)
const GA_MEASUREMENT_ID = "G-73S2NQZMRW";
